FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /workspace

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential wget \
    && rm -rf /var/lib/apt/lists/*

COPY Common/Frontend/requirements.reitteratsel.txt /tmp/requirements.reitteratsel.txt
RUN pip install --no-cache-dir -r /tmp/requirements.reitteratsel.txt
